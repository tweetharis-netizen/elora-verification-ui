{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev:server": "tsx watch server/index.ts",
    "dev:client": "vite --port=3000 --host 0.0.0.0",
    "dev:all": "concurrently --kill-others --names \"SERVER,CLIENT\" --prefix-colors \"cyan,magenta\" \"npm run dev:server\" \"npm run dev:client\"",
    "dev:local": "concurrently --names \"SERVER,CLIENT\" --prefix-colors \"cyan,magenta\" \"npm run dev:server\" \"npm run dev:client\"",
    "start": "npm run dev:local",
    "build": "vite build",
    "vercel-build": "vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "test:copilot": "tsx scripts/test-copilot-v3-behavior.mts && tsx scripts/test-student-modes.mts && tsx scripts/test-copilot-files.mts && tsx scripts/test-copilot-suggestions.mts && tsx scripts/test-copilot-artifacts.mts && tsx scripts/test-copilot-quick-actions.mts && tsx scripts/test-student-copilot-guardrails.mts && tsx scripts/test-student-copilot-review.mts && tsx scripts/test-reference-mentions.mts && tsx scripts/test-copilot-client-wiring.mts",
    "predeploy:copilot": "npm run lint && npm run build && npm run test:copilot",
    "test": "npm run test:copilot"
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@tailwindcss/vite": "^4.1.14",
    "@types/multer": "^2.1.0",
    "@vitejs/plugin-react": "^5.0.4",
    "better-sqlite3": "^12.4.1",
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.5",
    "pdfjs-dist": "^5.7.284",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-router-dom": "^7.13.0",
    "recharts": "^3.7.0",
    "tailwind-merge": "^3.5.0",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/nodemailer": "^8.0.0",
    "@types/react-test-renderer": "^19.1.0",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.1",
    "react-test-renderer": "^19.2.5",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
